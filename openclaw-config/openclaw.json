{
  "meta": {
    "lastTouchedAt": "2026-02-21T21:47:18.428Z",
    "lastTouchedVersion": "2026.2.21-2"
  },
  "browser": {
    "headless": true,
    "noSandbox": true,
    "defaultProfile": "openclaw"
  },
  "models": {
    "mode": "merge",
    "providers": {
      "minimax": {
        "baseUrl": "https://api.minimax.io/anthropic",
        "apiKey": "${MINIMAX_API_KEY}",
        "api": "anthropic-messages",
        "models": [
          {
            "id": "MiniMax-M2.1",
            "name": "MiniMax M2.1",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 15, "output": 60, "cacheRead": 2, "cacheWrite": 10 },
            "contextWindow": 200000,
            "maxTokens": 8192
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "minimax/MiniMax-M2.1"
      },
      "models": {
        "openai/gpt-5.2": { "alias": "ChatGPT 5.2" },
        "openai/gpt-5.1-codex": { "alias": "ChatGPT 5.1 Codex" },
        "openai/gpt-5": { "alias": "ChatGPT 5" },
        "openai/gpt-5-mini": { "alias": "ChatGPT 5 Mini" },
        "openai/gpt-4.1": { "alias": "ChatGPT 4.1" },
        "minimax/MiniMax-M2.1": { "alias": "minimax" }
      }
    },
    "list": [
      { "id": "main", "name": "main" }
    ]
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "bash": true,
    "restart": true,
    "ownerDisplay": "raw"
  },
  "hooks": {
    "token": "REDACTED"
  },
  "channels": {
    "whatsapp": {
      "dmPolicy": "allowlist",
      "selfChatMode": true,
      "allowFrom": [],
      "groupAllowFrom": [],
      "groupPolicy": "allowlist",
      "debounceMs": 0,
      "mediaMaxMb": 50
    },
    "telegram": {
      "dmPolicy": "pairing",
      "groupPolicy": "allowlist",
      "streaming": true
    }
  },
  "gateway": {
    "mode": "local",
    "controlUi": {
      "allowInsecureAuth": true,
      "dangerouslyDisableDeviceAuth": true
    },
    "auth": {
      "mode": "token",
      "token": "REDACTED"
    },
    "trustedProxies": ["127.0.0.1/32"],
    "remote": {
      "token": "REDACTED"
    }
  },
  "plugins": {
    "entries": {
      "whatsapp": { "enabled": true },
      "discord": { "enabled": true },
      "imessage": { "enabled": false },
      "telegram": { "enabled": true },
      "slack": { "enabled": true },
      "nostr": { "enabled": true },
      "signal": { "enabled": false },
      "googlechat": { "enabled": true }
    }
  },
  "env": {}
}
